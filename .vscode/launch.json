{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File (uCore)",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "/Users/fredbook/Code/uCore/backend/.venv/bin/python",
      "env": {
        "PYTHONPATH": "/Users/fredbook/Code/uCore/backend"
      },
      "cwd": "/Users/fredbook/Code/uCore"
    },
    {
      "name": "Python: Backend Server",
      "type": "python",
      "request": "launch",
      "program": "-m",
      "args": ["backend.app"],
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "/Users/fredbook/Code/uCore/backend/.venv/bin/python",
      "env": {
        "PYTHONPATH": "/Users/fredbook/Code/uCore/backend"
      },
      "cwd": "/Users/fredbook/Code/uCore"
    },
    {
      "name": "Node: gridcore",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder:gridcore}/node_modules/.bin/vitest",
      "runtimeArgs": ["run"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "cwd": "${workspaceFolder:gridcore}"
    },
    {
      "name": "Node: Attach to vitest",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "localhost",
      "localRoot": "${workspaceFolder:gridcore}",
      "remoteRoot": "${workspaceFolder:gridcore}"
    }
  ]
}