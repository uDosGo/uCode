{
  "name": "@udos/gridcore",
  "version": "1.0.0",
  "description": "Pure grid algebra core for uDos surfaces",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs,iife --global-name uDosGridCore --dts",
    "dev": "tsup src/index.ts --format esm,cjs,iife --global-name uDosGridCore --dts --watch",
    "test": "vitest run"
  },
  "keywords": [
    "grid",
    "algebra",
    "teletext",
    "ucode",
    "viewport"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.2.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
