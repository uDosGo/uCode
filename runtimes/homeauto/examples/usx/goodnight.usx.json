{
  "meta": {
    "version": "1.0",
    "name": "goodnight",
    "label": "Goodnight Scene",
    "description": "Lights off, doors locked, media paused",
    "author": "HomeNest",
    "created": "2026-05-17T18:00:00Z",
    "tags": ["scene", "night", "automation"]
  },
  "actions": [
    {
      "id": "lights-off",
      "type": "ha_light",
      "target": "light.living_room",
      "params": { "state": "off" }
    },
    {
      "id": "lights-bedroom-off",
      "type": "ha_light",
      "target": "light.bedroom",
      "params": { "state": "off" }
    },
    {
      "id": "lock-doors",
      "type": "ha_lock",
      "target": "lock.front_door",
      "params": { "state": "locked" }
    },
    {
      "id": "pause-media",
      "type": "media_pause",
      "target": "media.living_room_tv"
    },
    {
      "id": "set-alarm",
      "type": "ha_alarm",
      "target": "alarm_control_panel.main",
      "params": { "state": "armed_night" },
      "delay": 30.0
    }
  ],
  "surface": {
    "id": "goodnight-surface",
    "layout": "grid",
    "columns": 2,
    "rows": 3,
    "gap": 8,
    "tiles": [
      { "id": "lights", "label": "Lights Off", "icon": "lightbulb", "action": "lights-off", "position": { "x": 0, "y": 0 } },
      { "id": "lock", "label": "Lock Doors", "icon": "lock", "action": "lock-doors", "position": { "x": 1, "y": 0 } },
      { "id": "media", "label": "Pause Media", "icon": "pause", "action": "pause-media", "position": { "x": 0, "y": 1 } },
      { "id": "alarm", "label": "Arm Alarm", "icon": "shield", "action": "set-alarm", "position": { "x": 1, "y": 1 } }
    ]
  },
  "theme": {
    "name": "night",
    "colors": {
      "primary": "#1e3a5f",
      "background": "#0a0a1a",
      "text": "#e0e0ff"
    }
  }
}
