{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://usx.dev/schema/lens-v1",
  "title": "USX LENS Schema",
  "description": "Defines the dynamic state and variables for a USX surface. LENS describes 'what' — the data, state, and variables that drive the UI.",
  "type": "object",
  "version": "1.0.0",
  "definitions": {
    "variable": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "array", "object", "color", "enum"]
        },
        "default": {},
        "description": { "type": "string" },
        "required": { "type": "boolean", "default": false },
        "enum_values": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed values for enum type"
        },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "pattern": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "component_state": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "states": {
          "type": "object",
          "patternProperties": {
            "^[a-zA-Z_][a-zA-Z0-9_]*$": {
              "type": "object",
              "properties": {
                "props": { "type": "object" },
                "style_overrides": { "type": "object" }
              }
            }
          }
        },
        "current_state": { "type": "string" }
      },
      "required": ["type", "states"]
    }
  },
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "default": "1.0.0"
    },
    "variables": {
      "type": "object",
      "description": "Global variables available to the surface",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/definitions/variable" }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "object",
      "description": "Component state definitions",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/definitions/component_state" }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "description": "Runtime state variables (session, user, connection)",
      "properties": {
        "session_id": { "type": "string" },
        "user": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "email": { "type": "string" },
            "avatar": { "type": "string" }
          }
        },
        "connection_status": {
          "type": "string",
          "enum": ["connected", "disconnected", "reconnecting", "offline"]
        },
        "last_sync": { "type": "string", "format": "date-time" },
        "unsaved_changes": { "type": "boolean" }
      }
    },
    "features": {
      "type": "object",
      "description": "Feature flags for the surface",
      "additionalProperties": { "type": "boolean" }
    },
    "data": {
      "type": "object",
      "description": "Arbitrary data store for the surface",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
