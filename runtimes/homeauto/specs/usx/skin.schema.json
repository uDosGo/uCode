{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://usx.dev/schema/skin-v1",
  "title": "USX SKIN Schema",
  "description": "Defines the visual styling and theme for a USX surface. SKIN describes 'how' — the colors, typography, spacing, and component styles.",
  "type": "object",
  "version": "1.0.0",
  "definitions": {
    "color_token": {
      "type": "object",
      "properties": {
        "light": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "dark": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "description": { "type": "string" },
        "css_variable": { "type": "string" }
      },
      "required": ["light"],
      "additionalProperties": false
    },
    "typography_token": {
      "type": "object",
      "properties": {
        "font_family": { "type": "string" },
        "font_size": { "type": "string" },
        "font_weight": { "type": "integer", "minimum": 100, "maximum": 900 },
        "line_height": { "type": "number" },
        "letter_spacing": { "type": "string" },
        "text_transform": {
          "type": "string",
          "enum": ["none", "uppercase", "lowercase", "capitalize"]
        }
      },
      "required": ["font_family", "font_size"],
      "additionalProperties": false
    },
    "spacing_token": {
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["value"],
      "additionalProperties": false
    },
    "effect_token": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["shadow", "blur", "scanline", "gradient", "border", "animation"]
        },
        "value": { "type": "string" },
        "css": { "type": "string" }
      },
      "required": ["type", "value"],
      "additionalProperties": false
    },
    "component_skin": {
      "type": "object",
      "properties": {
        "base": { "type": "string", "description": "CSS class for base styling" },
        "variants": {
          "type": "object",
          "description": "Variant overrides (e.g., primary, secondary, danger)",
          "additionalProperties": { "type": "string" }
        },
        "states": {
          "type": "object",
          "description": "State overrides (e.g., hover, active, disabled)",
          "additionalProperties": { "type": "string" }
        },
        "custom_properties": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "default": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "Unique skin identifier"
    },
    "name": {
      "type": "string",
      "description": "Human-readable skin name"
    },
    "inherits": {
      "type": "string",
      "description": "Parent skin URI to inherit from"
    },
    "framework": {
      "type": "string",
      "description": "Target CSS framework (e.g., 'tailwind', 'bootstrap', 'custom')"
    },
    "colors": {
      "type": "object",
      "description": "Color palette tokens",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/definitions/color_token" }
      },
      "additionalProperties": false
    },
    "typography": {
      "type": "object",
      "description": "Typography scale tokens",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/definitions/typography_token" }
      },
      "additionalProperties": false
    },
    "spacing": {
      "type": "object",
      "description": "Spacing scale tokens",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/definitions/spacing_token" }
      },
      "additionalProperties": false
    },
    "effects": {
      "type": "object",
      "description": "Visual effects (shadows, scanlines, animations)",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/definitions/effect_token" }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "object",
      "description": "Component-specific skin overrides",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/definitions/component_skin" }
      },
      "additionalProperties": false
    },
    "extended": {
      "type": "object",
      "description": "Framework-specific or custom extensions",
      "additionalProperties": true
    }
  },
  "required": ["id", "name", "colors"],
  "additionalProperties": false
}
