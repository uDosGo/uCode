{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://usx.dev/schema/bundle-v1",
  "title": "USX Bundle Schema",
  "description": "A complete USX bundle combining LENS (state), SKIN (styling), and Layout (structure) into a single portable file.",
  "type": "object",
  "version": "1.0.0",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Bundle format version",
      "default": "1.0.0"
    },
    "id": {
      "type": "string",
      "description": "Unique bundle identifier (UUID or path-based)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable bundle name"
    },
    "description": {
      "type": "string",
      "description": "Bundle description"
    },
    "source": {
      "type": "object",
      "description": "Source tool metadata",
      "properties": {
        "tool": {
          "type": "string",
          "enum": ["figma", "adobe_xd", "monodraw", "ucode3", "ucode4", "manual", "other"]
        },
        "version": { "type": "string" },
        "exported_at": { "type": "string", "format": "date-time" },
        "exported_by": { "type": "string" }
      },
      "additionalProperties": false
    },
    "lens": {
      "$ref": "https://usx.dev/schema/lens-v1",
      "description": "Dynamic state and variables"
    },
    "skin": {
      "$ref": "https://usx.dev/schema/skin-v1",
      "description": "Visual styling and theme"
    },
    "layout": {
      "$ref": "https://usx.dev/schema/layout-v1",
      "description": "Structural layout"
    },
    "meta": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "related_bundles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preview_image": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "required": ["id", "name", "lens", "skin", "layout"],
  "additionalProperties": false
}
