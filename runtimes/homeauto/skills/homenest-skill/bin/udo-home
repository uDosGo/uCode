#!/usr/bin/env bash
#
# udo home — HomeNest CLI
# Communicates with homenest-mcp via Unix socket
#

set -euo pipefail

SOCKET_PATH="${HOMENEST_SOCKET:-/tmp/homenest-mcp.sock}"
MCP_BIN="${HOMENEST_MCP_BIN:-homenest-mcp}"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

usage() {
    cat <<EOF
HomeNest CLI — Media, Automation, TV/DVR

Usage:
  udo home status                    Show system status
  udo home media list                List media files
  udo home media play <id>           Play media
  udo home media pause               Pause playback
  udo home media stop                Stop playback
  udo home scene list                List available scenes
  udo home scene trigger <name>      Trigger automation scene
  udo home tv epg                    Show TV guide
  udo home tv tune <channel>         Tune to channel
  udo home tv record <ch> [dur]      Record channel
  udo home compile <path>            Compile USX bundle
EOF
}

send_mcp_request() {
    local method="$1"
    local params="${2:-{}}"

    if [ -S "$SOCKET_PATH" ]; then
        # Send via Unix socket using socat or nc
        local request
        request=$(printf '{"jsonrpc":"2.0","method":"%s","params":%s,"id":1}' "$method" "$params")
        echo "$request" | socat - UNIX-CONNECT:"$SOCKET_PATH" 2>/dev/null || \
        echo "$request" | nc -U "$SOCKET_PATH" 2>/dev/null || \
        echo '{"error":"Socket unavailable"}'
    else
        # Fallback: run the MCP binary directly
        $MCP_BIN "$method" "$params" 2>/dev/null || echo '{"error":"MCP binary not available"}'
    fi
}

format_json() {
    echo "$1" | python3 -m json.tool 2>/dev/null || echo "$1"
}

cmd_status() {
    echo -e "${BLUE}HomeNest Status${NC}"
    echo "───────────────────────────────"
    local resp
    resp=$(send_mcp_request "SystemStatus")
    echo "$resp" | format_json
}

cmd_media_list() {
    echo -e "${BLUE}Media Library${NC}"
    echo "───────────────────────────────"
    local resp
    resp=$(send_mcp_request "MediaList" '{"path":"/media"}')
    echo "$resp" | format_json
}

cmd_media_play() {
    local id="$1"
    echo -e "${GREEN}▶ Playing: $id${NC}"
    send_mcp_request "MediaPlay" "{\"media_id\":\"$id\"}" > /dev/null
    echo "OK"
}

cmd_media_pause() {
    echo -e "${YELLOW}⏸ Paused${NC}"
    send_mcp_request "MediaPause" > /dev/null
    echo "OK"
}

cmd_media_stop() {
    echo -e "${RED}⏹ Stopped${NC}"
    send_mcp_request "MediaStop" > /dev/null
    echo "OK"
}

cmd_scene_list() {
    echo -e "${BLUE}Available Scenes${NC}"
    echo "───────────────────────────────"
    local resp
    resp=$(send_mcp_request "AutomationStatus")
    echo "$resp" | format_json
}

cmd_scene_trigger() {
    local name="$1"
    echo -e "${GREEN}⚡ Triggering scene: $name${NC}"
    send_mcp_request "AutomationTrigger" "{\"scene\":\"$name\"}" > /dev/null
    echo "OK"
}

cmd_tv_epg() {
    echo -e "${BLUE}TV Guide${NC}"
    echo "───────────────────────────────"
    local resp
    resp=$(send_mcp_request "TvEpg")
    echo "$resp" | format_json
}

cmd_tv_tune() {
    local channel="$1"
    echo -e "${GREEN}📺 Tuning to channel: $channel${NC}"
    send_mcp_request "TvLive" "{\"channel\":\"$channel\"}" > /dev/null
    echo "OK"
}

cmd_tv_record() {
    local channel="$1"
    local duration="${2:-60}"
    echo -e "${RED}⏺ Recording channel $channel for ${duration}m${NC}"
    send_mcp_request "TvRecord" "{\"channel\":\"$channel\",\"duration\":$duration}" > /dev/null
    echo "OK"
}

cmd_compile() {
    local path="$1"
    if [ ! -f "$path" ]; then
        echo -e "${RED}Error: File not found: $path${NC}" >&2
        exit 1
    fi
    echo -e "${BLUE}Compiling USX bundle: $path${NC}"
    echo "───────────────────────────────"
    local resp
    resp=$(send_mcp_request "UsxCompile" "{\"path\":\"$path\"}")
    echo "$resp" | format_json
}

# Main dispatch
case "${1:-help}" in
    status) cmd_status ;;
    media)
        case "${2:-help}" in
            list) cmd_media_list ;;
            play) cmd_media_play "${3:-}";;
            pause) cmd_media_pause ;;
            stop) cmd_media_stop ;;
            *) echo -e "${YELLOW}Usage: udo home media {list|play|pause|stop}${NC}" >&2; exit 1 ;;
        esac
        ;;
    scene)
        case "${2:-help}" in
            list) cmd_scene_list ;;
            trigger) cmd_scene_trigger "${3:-}";;
            *) echo -e "${YELLOW}Usage: udo home scene {list|trigger}${NC}" >&2; exit 1 ;;
        esac
        ;;
    tv)
        case "${2:-help}" in
            epg) cmd_tv_epg ;;
            tune) cmd_tv_tune "${3:-}";;
            record) cmd_tv_record "${3:-}" "${4:-}";;
            *) echo -e "${YELLOW}Usage: udo home tv {epg|tune|record}${NC}" >&2; exit 1 ;;
        esac
        ;;
    compile) cmd_compile "${2:-}";;
    help|--help|-h) usage ;;
    *) echo -e "${YELLOW}Unknown command: $1${NC}" >&2; usage; exit 1 ;;
esac
