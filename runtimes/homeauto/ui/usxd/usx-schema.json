{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://udos.dev/schemas/usx/v1",
  "title": "USX — Universal Surface eXchange Format",
  "description": "Schema for HomeNest USX files defining UDO (rich UI) and UDX (terminal) surfaces",
  "type": "object",
  "required": ["meta", "version"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "surface"],
      "properties": {
        "title": { "type": "string", "maxLength": 80 },
        "description": { "type": "string", "maxLength": 400 },
        "surface": { "enum": ["udo", "udx", "both"] },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "author": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "udo": {
      "type": "object",
      "properties": {
        "theme": { "enum": ["dark", "light", "auto"] },
        "layout": { "enum": ["grid", "list", "carousel", "fullscreen"] },
        "components": { "type": "array", "items": { "$ref": "#/definitions/udoComponent" } }
      }
    },
    "udx": {
      "type": "object",
      "properties": {
        "grid": { "type": "string", "pattern": "^\\d+x\\d+$", "default": "40x24" },
        "font": { "enum": ["Teletext50", "Teletext50 Extended", "Teletext50 Condensed"] },
        "palette": { "enum": ["green", "amber", "cyan", "white"] },
        "content": { "type": "array", "items": { "type": "string", "maxLength": 40 } }
      }
    },
    "actions": {
      "type": "object",
      "properties": {
        "on_load": { "type": "array", "items": { "$ref": "#/definitions/action" } },
        "on_select": { "type": "array", "items": { "$ref": "#/definitions/action" } },
        "on_timer": { "type": "array", "items": { "$ref": "#/definitions/timedAction" } }
      }
    }
  },
  "definitions": {
    "udoComponent": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["card", "button", "playlist", "tvguide", "slider", "toggle", "modal", "grid", "list", "hero", "badge", "progress", "status"] },
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "icon": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "items": { "type": "array" },
        "value": { "type": ["string", "number", "boolean"] },
        "progress": { "type": "number", "minimum": 0, "maximum": 100 },
        "status": { "enum": ["active", "inactive", "warning", "error", "success"] },
        "columns": { "type": "integer", "minimum": 1, "maximum": 12 },
        "onClick": { "$ref": "#/definitions/action" }
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["media", "sunshine", "ha", "matter", "esphome", "system", "delay", "notify", "navigate", "api"] },
        "command": { "type": "string" },
        "parameters": { "type": "object" }
      }
    },
    "timedAction": {
      "type": "object",
      "required": ["delay", "action"],
      "properties": {
        "delay": { "type": "integer", "minimum": 0 },
        "action": { "$ref": "#/definitions/action" }
      }
    }
  }
}
