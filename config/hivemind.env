# Hivemind MCP — API Keys for uCode (Local-First Mode)
# Priority: Ollama (free) → OpenRouter (paid fallback)
# Copy to ~/.config/hivemind/.env and fill in your keys
# chmod 600 ~/.config/hivemind/.env

# ── Default provider ──────────────────────────────────────────────────────────
HIVE_DEFAULT_PROVIDER="ollama"
HIVE_DEFAULT_MODEL="qwen2.5-coder:3b"

# ── Local Ollama (free, offline-first) ────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_DEFAULT_MODEL="qwen2.5-coder:3b"
OLLAMA_FALLBACK_MODEL="qwen2.5-coder:7b"

# ── OpenRouter (cloud fallback — only used when Ollama unavailable) ───────────
OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENROUTER_DEFAULT_MODEL="deepseek/deepseek-v4-flash"
OPENROUTER_FALLBACK_MODEL="qwen/qwen3.6-27b"

# ── Other providers (optional, opt-in) ────────────────────────────────────────
# ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"